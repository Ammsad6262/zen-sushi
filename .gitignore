# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# ZEN-specific: don't commit local screenshots/uploads
/download/
/upload/
/worklog.md

# Scaffold demo folders — not part of the ZEN Sushi app
/examples/
/mini-services/
/skills/

# Local database
/db/
/prisma/*.db
/prisma/*.db-journal

# Z-ai internal scripts
/.zscripts/

# Local order data (customer orders saved to localStorage on the client,
# but if we ever cache them server-side, don't commit them)
/orders.json
/zen-orders.json